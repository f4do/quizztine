# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/quizztine
POSTGRES_DB=quizztine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Server
NODE_ENV=development
PORT=3000

# JWT (required in production — startup fails if missing)
JWT_SECRET=change-this-in-production

# CORS — origine autorisée (ex: http://localhost:5173 en dev, votre-domaine.com en prod)
CORS_ORIGIN=http://localhost:5173

# Uploads — dossier de stockage des médias (images, audio)
UPLOAD_DIR=/app/uploads

# Logging — niveau de détail (info, debug, warn, error)
LOG_LEVEL=info

# Frontend (injectés au build via Vite)
VITE_API_URL=/api
VITE_SOCKET_URL=/
VITE_DEFAULT_LANG=fr

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/quizztine
POSTGRES_DB=quizztine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT (required in production — startup fails if missing)
JWT_SECRET=change-this-in-production

# CORS
CORS_ORIGIN=http://localhost:5173

# Uploads
UPLOAD_DIR=/app/uploads

# Quiz Engine (internal)
QUIZ_ENGINE_URL=http://quiz-engine:8000

# Frontend
VITE_API_URL=/api
VITE_SOCKET_URL=/
VITE_DEFAULT_LANG=fr

# Engine
BACKEND_URL=http://web-backend:3000
LOG_LEVEL=INFO
